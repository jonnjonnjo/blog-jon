---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostList from "../components/PostList.astro";

const posts = (
  await getCollection("posts", ({ data }) =>
    import.meta.env.PROD ? !data.draft : true
  )
).sort(
  (a, b) =>
    (b.data.date?.getTime() ?? Date.now()) -
    (a.data.date?.getTime() ?? Date.now())
);
---

<BaseLayout>
  <header class="header">
    <div class="header-row">
      <h1>Jonathan Arthurito Aldi Sinaga</h1>
      <button class="theme-toggle" type="button" aria-live="polite">theme: light</button>
    </div>
    <p>大家好! This blog mainly contains technical-related blog！</p>
    <p><a href="https://jonarthurito.substack.com/" target="_blank" rel="noopener noreferrer">checkout my substack!</a></p>
  </header>
  <main>
    <PostList posts={posts} />
  </main>
</BaseLayout>
